# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/callmatrix

# Redis (rate limiting; required at startup)
REDIS_URL=redis://localhost:6379

# JWT — use a long random secret in production (32+ characters)
JWT_SECRET=replace-with-a-long-random-secret-value-32chars
JWT_EXPIRES_IN=7d

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Frontend origin for CORS (Vite default). Omit in dev to reflect request origin.
CORS_ORIGIN=http://localhost:5173

BCRYPT_ROUNDS=12

# Global API rate limit (Redis-backed)
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# Stricter bucket for POST /auth/login
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Prisma seed: first super admin (role=admin). Optional — omit to skip seed.
# Match the frontend admin panel login (see frontend AdminLogin) for local dev:
ADMIN_EMAIL=admin@callmatrix.ai
ADMIN_PASSWORD=admin123
