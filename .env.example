# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# Data stores (replace with your values)
MONGO_URI=mongodb://localhost:27017/your_database_name
REDIS_URL=redis://localhost:6379

# MongoDB Atlas: the copied URI often contains <db_password>. Either:
#   (A) Set MONGO_PASSWORD to your database user password (recommended; special chars are encoded), or
#   (B) Replace <db_password> in MONGO_URI with the password URL-encoded (e.g. @ becomes %40).
# Optional if your URI uses <db_username>: MONGO_USERNAME=yourUser
# MONGO_PASSWORD=

# Optional: comma-separated DNS servers for mongodb+srv SRV resolution issues
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional CORS origin (string). If unset: permissive in development, disabled in production.
# CORS_ORIGIN=https://your-frontend.example

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
